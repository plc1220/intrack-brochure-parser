# AWS credentials: use AWS_PROFILE, or AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY.
# The IAM principal needs bedrock:InvokeModel on the model below (enable it in the Bedrock console).
AWS_REGION="ap-southeast-1"
BEDROCK_MODEL_ID="apac.amazon.nova-lite-v1:0"

# APP_URL: The URL where this applet is hosted (optional).
APP_URL="MY_APP_URL"
